    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver-es": "^2.0.5",
    "lowlight": "^3.3.0",
    "marked": "^17.0.6",
    "ngx-markdown": "^21.2.0",
    "ngx-scrollbar": "^18.0.0",
    "ngx-sonner": ">=3.0.0",
    "ngx-tiptap": "^14.0.1",
    "prismjs": "^1.29.0",
    "rxjs": "^7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "firebase": "^12.9.0",
    "@stoplight/elements": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  },
  "devDependencies": {
    "@angular-eslint/builder": "~21.2.0",
    "@angular-eslint/eslint-plugin": "~21.2.0",
    "@angular-eslint/eslint-plugin-template": "~21.2.0",

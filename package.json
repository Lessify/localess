{
  "name": "localess",
  "version": "3.0.1",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.cjs",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:docker": "ng build --configuration docker",
    "prebuild:prod": "ng g @lessify/angular-tools:set-env --prefix LOCALESS",
    "build:script:tsup": "tsup scripts/sync-v1.ts --format cjs --minify --outDir src/scripts",
    "build:script:watch": "tsc --watch --project tsconfig.script.json",
    "watch": "ng build --watch --configuration development",
    "emulator": "firebase emulators:start --import=./firebase-export --export-on-exit=./firebase-export",
    "emulator:debug": "firebase emulators:start --debug --import=./firebase-export --export-on-exit=./firebase-export",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "prettier": "prettier --check ./src/app",
    "prettier:fix": "prettier --write ./src/app",
    "build:stats": "ng build --configuration production --stats-json",
    "generate:github": "ng-openapi-gen --includeTags repos -i api-docs/api.github.com.2022-11-28.yaml -o src/app/shared/generated/github",
    "version:generate": "node scripts/generate-version.js"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ng-icons/core": "^33.1.0",
    "@ng-icons/lucide": "^33.1.0",
    "@ng-icons/tabler-icons": "^33.1.0",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/signals": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@spartan-ng/brain": "^0.0.1-alpha.644",
    "@stoplight/elements": "^9.0.16",
    "@tiptap/core": "^2.7.1",
    "@tiptap/extension-bold": "^2.7.1",
    "@tiptap/extension-bubble-menu": "^2.7.1",
    "@tiptap/extension-bullet-list": "^2.7.1",
    "@tiptap/extension-code": "^2.7.1",
